# CogniFlow Backend Configuration
# ==================================
# Copy this to .env and fill in your values

# REQUIRED: Anthropic API Key
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Cache
CACHE_DIR=./cache
CACHE_TTL_SECONDS=86400  # 24 hours

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=30
MAX_PARAGRAPHS_PER_REQUEST=20

# Model Configuration
# Using claude-sonnet-4-20250514 for cost efficiency on high-volume simplification
# Switch to claude-opus-4-20250514 for higher quality if budget allows
MODEL_NAME=claude-sonnet-4-20250514
MAX_TOKENS_PER_CALL=2048
